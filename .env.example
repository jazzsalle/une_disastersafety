# 환경변수 템플릿 — 실제 값은 이 파일을 .env로 복사해 기입 (.env는 gitignore 대상)

# VWorld 인증키 (www.vworld.kr 발급 — 하나의 키를 두 변수에 공용 기입)
# 프론트엔드(Vite) 지도 타일용
VITE_VWORLD_API_KEY=
# 파이프라인(지오코더·2D데이터 API)용
VWORLD_API_KEY=

# Claude API 키 (선택 — 미설정 시 mock 응답 모드로 동작)
ANTHROPIC_API_KEY=

# UNI RAG System 챗봇 연동 (docs/06 참조 — 미설정 시 챗봇 mock 폴백)
UNI_RAG_BASE_URL=http://221.147.100.161:8000
# UNE 계정 (자격증명 커밋 금지 — .env에만 기입)
UNI_RAG_ACCOUNT=
UNI_RAG_PASSWORD=
# 모델 키 (선택: qwen3.5-35b | exaone-32b | qwen3-coder-next, 미설정 시 서버 기본)
UNI_RAG_MODEL_KEY=
